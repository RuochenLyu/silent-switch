    "quit.confirm.message" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Quitting stops all hotkeys. Closing the window keeps them active in the background." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "退出后将停止监听快捷键。只关闭窗口会继续在后台运行。" } }
